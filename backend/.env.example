NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgresql://velora:velora_password@localhost:5432/velora?schema=public
JWT_SECRET=replace-with-a-random-development-secret-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Try-on ML CLI execution is disabled by default.
TRY_ON_ML_ENABLED=false
TRY_ON_ML_PYTHON_COMMAND=python
TRY_ON_ML_COMMAND_ARGS=-m,src.main,catvton-research
TRY_ON_ML_WORKING_DIRECTORY=../ml
TRY_ON_ML_PERSON_IMAGE_ROOT=storage/try-on/person
TRY_ON_ML_CATALOG_GARMENT_ROOT=storage/try-on/catalog-garments
TRY_ON_ML_WARDROBE_GARMENT_ROOT=storage/try-on/wardrobe-garments
TRY_ON_ML_OUTPUT_DIRECTORY=storage/try-on/results
TRY_ON_ML_PERSON_IMAGE_PATH_TEMPLATE={personImageAssetId}
TRY_ON_ML_CATALOG_GARMENT_PATH_TEMPLATE={productId}.png
TRY_ON_ML_WARDROBE_GARMENT_PATH_TEMPLATE={wardrobeItemId}.png
TRY_ON_ML_CLOTH_TYPE=upper
TRY_ON_ML_SEED=42
TRY_ON_ML_INFERENCE_STEPS=30
TRY_ON_ML_GUIDANCE_SCALE=2.5
TRY_ON_ML_WIDTH=768
TRY_ON_ML_HEIGHT=1024
TRY_ON_ML_DEVICE=cuda
TRY_ON_ML_BASE_MODEL_PATH=runwayml/stable-diffusion-inpainting
TRY_ON_ML_RESUME_PATH=zhengchong/CatVTON
TRY_ON_ML_TIMEOUT_MS=600000
