generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WardrobeItemStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DELETION_PENDING
}

enum WardrobeItemMediaPurpose {
  PRIMARY
}

enum WardrobeItemMediaStatus {
  UPLOADING
  READY
  FAILED
  DELETION_PENDING
}

enum TryOnJobStatus {
  QUEUED
  VALIDATING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum TryOnResultStatus {
  READY
  FAILED
  DELETION_PENDING
  DELETED
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique
  passwordHash        String
  displayName         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  wishlist            Wishlist?
  outfits             Outfit[]
  analyticsEvents     AnalyticsEvent[]
  redirectEvents      RedirectEvent[]
  passwordResetTokens PasswordResetToken[]
  wardrobeItems       WardrobeItem[]
  tryOnConsents       TryOnConsent[]
  tryOnJobs           TryOnJob[]
  tryOnResults        TryOnResult[]

  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Brand {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([isActive])
}

model Category {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @unique
  slug          String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  products      Product[]
  wardrobeItems WardrobeItem[]

  @@index([isActive])
}

model SourcePlatform {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @unique
  slug           String          @unique
  baseUrl        String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]
  redirectEvents RedirectEvent[]

  @@index([isActive])
}

model Product {
  id               String           @id @default(uuid()) @db.Uuid
  title            String
  brandId          String           @db.Uuid
  categoryId       String           @db.Uuid
  sourcePlatformId String           @db.Uuid
  price            Decimal          @db.Decimal(10, 2)
  imageUrl         String
  productUrl       String
  color            String
  description      String?
  availableColors  String[]         @default([])
  tags             String[]         @default([])
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  brand            Brand            @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category         Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sourcePlatform   SourcePlatform   @relation(fields: [sourcePlatformId], references: [id], onDelete: Restrict)
  wishlistItems    WishlistItem[]
  outfitProducts   OutfitProduct[]
  analyticsEvents  AnalyticsEvent[]
  redirectEvents   RedirectEvent[]
  tryOnJobs        TryOnJob[]

  @@index([title])
  @@index([brandId])
  @@index([categoryId])
  @@index([sourcePlatformId])
  @@index([color])
  @@index([price])
  @@index([isActive])
  @@index([categoryId, price])
  @@index([brandId, categoryId])
}

model Wishlist {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @unique @db.Uuid
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(uuid()) @db.Uuid
  wishlistId String   @db.Uuid
  productId  String   @db.Uuid
  createdAt  DateTime @default(now())
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([wishlistId, productId])
  @@index([wishlistId, createdAt])
  @@index([productId])
}

model Outfit {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @db.Uuid
  name            String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  products        OutfitProduct[]
  wardrobeItems   OutfitWardrobeItem[]
  analyticsEvents AnalyticsEvent[]
  redirectEvents  RedirectEvent[]
  tryOnJobs       TryOnJob[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([createdAt])
}

model OutfitProduct {
  id        String   @id @default(uuid()) @db.Uuid
  outfitId  String   @db.Uuid
  productId String   @db.Uuid
  createdAt DateTime @default(now())
  outfit    Outfit   @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([outfitId, productId])
  @@index([outfitId])
  @@index([productId])
  @@index([createdAt])
}

model OutfitWardrobeItem {
  id             String       @id @default(uuid()) @db.Uuid
  outfitId       String       @db.Uuid
  wardrobeItemId String       @db.Uuid
  createdAt      DateTime     @default(now())
  outfit         Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItem   WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@unique([outfitId, wardrobeItemId])
  @@index([outfitId])
  @@index([wardrobeItemId])
}

model WardrobeItem {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @db.Uuid
  categoryId      String               @db.Uuid
  title           String
  color           String?
  brandLabel      String?
  notes           String?
  status          WardrobeItemStatus   @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  analyticsEvents AnalyticsEvent[]
  media           WardrobeItemMedia[]
  outfits         OutfitWardrobeItem[]
  tryOnJobs       TryOnJob[]

  @@index([userId, status, updatedAt])
  @@index([userId, categoryId])
  @@index([categoryId])
}

model WardrobeItemMedia {
  id             String                   @id @default(uuid()) @db.Uuid
  wardrobeItemId String                   @db.Uuid
  storageKey     String                   @unique
  mediaType      String
  purpose        WardrobeItemMediaPurpose @default(PRIMARY)
  status         WardrobeItemMediaStatus  @default(UPLOADING)
  width          Int?
  height         Int?
  fileSize       Int?
  createdAt      DateTime                 @default(now())
  deletedAt      DateTime?
  wardrobeItem   WardrobeItem             @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@index([wardrobeItemId, status])
}

model AnalyticsEvent {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String?       @db.Uuid
  eventType      String
  productId      String?       @db.Uuid
  outfitId       String?       @db.Uuid
  wardrobeItemId String?       @db.Uuid
  sourceScreen   String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  product        Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  outfit         Outfit?       @relation(fields: [outfitId], references: [id], onDelete: SetNull)
  wardrobeItem   WardrobeItem? @relation(fields: [wardrobeItemId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([productId, eventType])
  @@index([outfitId, eventType])
  @@index([wardrobeItemId, eventType])
  @@index([eventType, createdAt])
}

model RedirectEvent {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String?        @db.Uuid
  productId        String         @db.Uuid
  outfitId         String?        @db.Uuid
  sourcePlatformId String         @db.Uuid
  sourceScreen     String
  createdAt        DateTime       @default(now())
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  product          Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  outfit           Outfit?        @relation(fields: [outfitId], references: [id], onDelete: SetNull)
  sourcePlatform   SourcePlatform @relation(fields: [sourcePlatformId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([productId, createdAt])
  @@index([outfitId, createdAt])
  @@index([sourcePlatformId, createdAt])
  @@index([sourceScreen, createdAt])
}

model TryOnConsent {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @db.Uuid
  policyVersion String
  purpose       String
  grantedAt     DateTime
  withdrawnAt   DateTime?
  createdAt     DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs          TryOnJob[]

  @@index([userId, grantedAt])
  @@index([userId, purpose, withdrawnAt])
}

model TryOnJob {
  id                    String         @id @default(uuid()) @db.Uuid
  userId                String         @db.Uuid
  consentId             String         @db.Uuid
  personImageStorageKey String?
  productId             String?        @db.Uuid
  wardrobeItemId        String?        @db.Uuid
  outfitId              String?        @db.Uuid
  status                TryOnJobStatus @default(QUEUED)
  provider              String?
  providerVersion       String?
  modelVersion          String?
  idempotencyKey        String?
  attemptCount          Int            @default(0)
  maxAttempts           Int            @default(3)
  failureCode           String?
  failureMessage        String?
  processingStartedAt   DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  expiresAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  consent               TryOnConsent   @relation(fields: [consentId], references: [id], onDelete: Restrict)
  product               Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  wardrobeItem          WardrobeItem?  @relation(fields: [wardrobeItemId], references: [id], onDelete: SetNull)
  outfit                Outfit?        @relation(fields: [outfitId], references: [id], onDelete: SetNull)
  result                TryOnResult?

  @@unique([userId, idempotencyKey])
  @@index([userId, status, createdAt])
  @@index([userId, createdAt])
  @@index([consentId])
  @@index([productId])
  @@index([wardrobeItemId])
  @@index([outfitId])
  @@index([expiresAt])
}

model TryOnResult {
  id           String            @id @default(uuid()) @db.Uuid
  jobId        String            @unique @db.Uuid
  userId       String            @db.Uuid
  storageKey   String            @unique
  mediaType    String
  width        Int?
  height       Int?
  fileSize     Int?
  provider     String
  modelVersion String?
  status       TryOnResultStatus @default(READY)
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())
  deletedAt    DateTime?
  job          TryOnJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt, deletedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
